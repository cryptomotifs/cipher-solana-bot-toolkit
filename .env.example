# cipher-solana-bot-toolkit — environment template
# Copy to .env and fill in your own values. NEVER commit .env.
# All modules share this single .env; per-module README says which vars it reads.

# ─── Trading Mode ────────────────────────────────────────
# true  = paper/dry-run (simulate only, safe)
# false = live trading (real funds — requires wallet + signing)
DRY_RUN=true

# ─── Solana RPC ──────────────────────────────────────────
# Comma-separated endpoints in priority order.
# Free options:
#   - https://api.mainnet-beta.solana.com              (public, rate-limited)
#   - https://rpc.ankr.com/solana                      (free tier)
#   - https://solana-mainnet.g.alchemy.com/v2/<KEY>    (free tier)
#   - https://mainnet.helius-rpc.com/?api-key=<KEY>    (free tier, 100k credits/mo)
RPC_URL=https://api.mainnet-beta.solana.com
RPC_ENDPOINTS=https://api.mainnet-beta.solana.com

# ─── API Keys (all free tiers) ───────────────────────────
# Helius — https://dev.helius.xyz/   (100K credits/mo free)
HELIUS_API_KEY=

# Alchemy — https://www.alchemy.com/  (optional backup RPC)
ALCHEMY_API_KEY=

# Chainstack — https://chainstack.com/  (optional, 5 RPS free)
CHAINSTACK_API_KEY=

# Birdeye — https://docs.birdeye.so/  (optional, price data)
BIRDEYE_API_KEY=

# Jupiter — no key required (public swap API)
# Pyth   — no key required (public price oracle)

# ─── Wallet ──────────────────────────────────────────────
# Option A — encrypted keyfile (AES-256-GCM, recommended)
WALLET_KEYFILE=keys/trading.enc
# WALLET_PASSWORD=            # decryption password (live mode only)

# Option B — plain JSON keypair path (NOT recommended for prod)
# WALLET_PATH=keys/id.json

# Option C — base58 secret (env only, never commit)
# PRIVATE_KEY=<YOUR_BASE58_SECRET>

# Public key, for verification / display only
# TRADING_WALLET_PUBKEY=<YOUR_WALLET>

# ─── Jito (volume bot, bundle submission) ────────────────
JITO_ENDPOINT=https://mainnet.block-engine.jito.wtf
# JITO_TIP_LAMPORTS=10000     # 0.00001 SOL default tip

# ─── Flash Loan Providers ────────────────────────────────
# MarginFi — zero-capital flash loan (requires marginfi_account PDA, auto-created)
MARGINFI_ENABLED=true
# MARGINFI_ACCOUNT=<YOUR_MARGINFI_ACCOUNT_PDA>  # set after first trade

# Kamino — lending market flash loans
KAMINO_ENABLED=true

# Orca Whirlpool — flash swap (needs USDC in wallet)
ORCA_ENABLED=true

# Raydium CLMM — flash swap (needs USDC in wallet)
RAYDIUM_ENABLED=true

# ─── Volume Bot ──────────────────────────────────────────
# Token mint (pump.fun migrated token) to run volume on
VOLUME_TOKEN_MINT=
# Wallets per bundle (Jito limit = 5 TXs incl. tip)
VOLUME_BUNDLE_WALLETS=4
# Trade size per wallet (SOL)
VOLUME_TRADE_SOL=0.005

# ─── Copy Trade ──────────────────────────────────────────
# Comma-separated base58 wallet addresses to follow
COPY_TRADE_TARGETS=
# Max SOL per copied trade
COPY_TRADE_MAX_SOL=0.05
# Delay after target's fill, ms
COPY_TRADE_DELAY_MS=500

# ─── Memecoin Launcher (pump.fun via PumpPortal) ─────────
# PumpPortal API key — https://pumpportal.fun/  (free)
PUMPPORTAL_API_KEY=
# Storage for token metadata (IPFS via pump.fun default is free)
# IPFS_ENDPOINT=https://ipfs.io

# ─── Telegram Alerts (optional) ──────────────────────────
# Create a bot with @BotFather and grab token + chat_id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Storage / Logging ───────────────────────────────────
DB_PATH=data/bot.db
LOG_DIR=logs/
LOG_LEVEL=INFO
